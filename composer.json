{
	"type": "project",
	"license": "MIT",
 	"require": {
		"php": ">=8.5",
		"ext-ctype": "*",
		"ext-iconv": "*",
		"api-platform/core": "^4.3.10",
		"api-platform/mcp": "^4.3.0",
		"beberlei/doctrineextensions": "^1.3",
		"darkwood/ia-exception-bundle": "^8.0.13",
		"darkwood/navi": "^8.0.13",
		"doctrine/dbal": "^4.2.0",
		"doctrine/doctrine-bundle": "^3.1",
		"doctrine/doctrine-migrations-bundle": "^4.0",
		"doctrine/orm": "^3.2.0",
		"endroid/qr-code": "^6.1",
		"google/recaptcha": "^1.5",
		"knplabs/knp-paginator-bundle": "^6.2.0",
		"knpuniversity/oauth2-client-bundle": "^2.16",
		"league/commonmark": "^2.4.1",
		"league/oauth2-facebook": "^2.2",
		"lexik/jwt-authentication-bundle": "^3.1",
		"liip/imagine-bundle": "^2.12",
		"nelmio/cors-bundle": "^2.5",
		"phpdocumentor/reflection-docblock": "^5.6",
		"phpstan/phpdoc-parser": "^2.1.0",
		"scheb/2fa-bundle": "^8.5",
		"scheb/2fa-totp": "^8.5",
		"sentry/sentry-symfony": "^5.0.1",
		"stof/doctrine-extensions-bundle": "^1.9",
		"symfony/ai-open-ai-platform": "^0.8.0",
		"symfony/asset": "^8.1",
		"symfony/console": "^8.1",
		"symfony/dotenv": "^8.1",
		"symfony/emoji": "^8.1",
		"symfony/expression-language": "^8.1",
		"symfony/flex": "^2.4.0",
		"symfony/form": "^8.1",
		"symfony/framework-bundle": "^8.1",
		"symfony/http-client": "^8.1",
		"symfony/intl": "^8.1",
		"symfony/mailer": "^8.1",
		"symfony/mcp-bundle": "^0.8.0",
		"symfony/mime": "^8.1",
		"symfony/monolog-bundle": "^4.0",
		"symfony/notifier": "^8.1",
		"symfony/object-mapper": "^8.1",
		"symfony/process": "^8.1",
		"symfony/property-access": "^8.1",
		"symfony/property-info": "^8.1",
		"symfony/psr-http-message-bridge": "^8.1",
		"symfony/rate-limiter": "^8.1",
		"symfony/runtime": "^8.1",
		"symfony/security-bundle": "^8.1",
		"symfony/serializer": "^8.1",
		"symfony/string": "^8.1",
		"symfony/translation": "^8.1",
		"symfony/twig-bundle": "^8.1",
		"symfony/validator": "^8.1",
		"symfony/web-link": "^8.1",
		"symfony/webpack-encore-bundle": "^2.1.1",
		"symfony/yaml": "^8.1",
		"symfonycasts/verify-email-bundle": "^1.14",
		"twig/extra-bundle": "^3.7.1",
		"twig/intl-extra": "^3.7.1",
		"twig/markdown-extra": "^3.7.1",
		"twig/string-extra": "^3.7.1",
		"twig/twig": "^3.27.1",
		"vich/uploader-bundle": "^2.8.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^13.2",
		"doctrine/doctrine-fixtures-bundle": "^4.1.0",
		"phpstan/extension-installer": "^1.4.0",
		"phpstan/phpstan": "^2.1.22",
		"symfony/browser-kit": "^8.1",
		"symfony/css-selector": "^8.1",
		"symfony/debug-bundle": "^8.1",
		"symfony/maker-bundle": "^1.51.1",
		"symfony/monolog-bundle": "^4.0",
		"symfony/phpunit-bridge": "^8.1",
		"symfony/stopwatch": "^8.1",
		"symfony/twig-bundle": "^8.1",
		"symfony/var-dumper": "^8.1",
		"symfony/web-profiler-bundle": "^8.1"
	},
	"config": {
		"optimize-autoloader": true,
		"preferred-install": {
			"*": "dist"
		},
		"sort-packages": true,
		"allow-plugins": {
			"phpstan/extension-installer": true,
			"symfony/flex": true,
			"symfony/runtime": true,
			"php-http/discovery": true
		}
	},
	"autoload": {
		"psr-4": {
			"App\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"App\\Tests\\": "tests/"
		}
	},
	"replace": {
		"paragonie/random_compat": "2.*",
		"symfony/polyfill-ctype": "*",
		"symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
	},
	"scripts": {
		"auto-scripts": {
			"cache:clear": "symfony-cmd",
			"assets:install %PUBLIC_DIR%": "symfony-cmd"
		},
		"post-install-cmd": [
			"@auto-scripts"
		],
		"post-update-cmd": [
			"@auto-scripts"
		],
		"env": "cd tools && castor app:tools:env",
        "php-cs-fixer": "cd tools && castor app:tools:php-cs-fixer",
        "phpstan": "cd tools && castor app:tools:phpstan",
        "phpunit": "cd tools && castor app:tools:phpunit"
	},
	"conflict": {
		"symfony/symfony": "*"
	},
	"extra": {
		"symfony": {
			"allow-contrib": false,
			"require": "^8.1"
		}
	}
}
