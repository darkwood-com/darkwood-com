<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Two-factor authentication</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f5f5f5; color: #111; margin: 0; }
        .shell { max-width: 32rem; margin: 5rem auto; background: #fff; border: 1px solid #ddd; padding: 2rem; }
        h1 { margin-top: 0; }
        .error { margin-bottom: 1rem; padding: .75rem 1rem; background: #fce8e6; color: #8a1f17; }
        .actions { margin-top: 1rem; display: flex; gap: 1rem; align-items: center; }
        input[type="text"] { width: 100%; padding: .75rem; font-size: 1rem; box-sizing: border-box; }
        button, .link { display: inline-block; padding: .75rem 1rem; text-decoration: none; }
        button { border: 0; background: #111; color: #fff; cursor: pointer; }
        .link { color: #111; }
    </style>
</head>
<body>
<div class="shell">
    <h1>Two-factor authentication</h1>

    {% if authenticationError %}
        <div class="error">{{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}</div>
    {% endif %}

    <p>Enter the 6-digit code from your authenticator app to complete sign-in.</p>

    <form action="{{ checkPathUrl ? checkPathUrl : path(checkPathRoute) }}" method="post">
        <label for="_auth_code">Authentication code</label>
        <input
            id="_auth_code"
            type="text"
            name="{{ authCodeParameterName }}"
            autocomplete="one-time-code"
            inputmode="numeric"
            pattern="[0-9]*"
            autofocus
        >

        {% if isCsrfProtectionEnabled %}
            <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
        {% endif %}

        <div class="actions">
            <button type="submit">Verify</button>
            <a class="link" href="{{ logoutPath }}">Cancel</a>
        </div>
    </form>
</div>
</body>
</html>
