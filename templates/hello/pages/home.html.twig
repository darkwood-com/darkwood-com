{% extends "hello/base.html.twig" %}

{% block javascript %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
    <script type="text/javascript" src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endblock %}

{% block body %}

{% set navItems = [
    { href: '#about', label: 'hello.menu.about'|trans },
    { href: '#work', label: 'hello.menu.work'|trans },
    { href: '#skills', label: 'hello.section.skills'|trans },
    { href: '#projects', label: 'hello.menu.projects'|trans },
    { href: '#blog', label: 'hello.menu.blog'|trans },
    { href: '#contact', label: 'hello.menu.contact'|trans }
] %}

<div class="container-fluid theme theme-hello">
    <nav class="navbar navbar-expand-lg navbar-light fixed-top main-nav" id="page-top">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand" href="#page-top"><img class="img-fluid" src="{{ asset('/hello/logo-uni-dark.png') }}" alt="darkwood logo" width="50px"></a>
            <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                Menu
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto">
                    {% for item in navItems %}
                        <li class="nav-item"><a class="nav-link" href="{{ item.href }}">{{ item.label }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </nav>
    <ul class="theme-mobile-nav hello-mobile-nav hello-mobile-nav--many">
        {% for item in navItems %}
            <li><a href="{{ item.href }}">{{ item.label }}</a></li>
        {% endfor %}
    </ul>
    <header class="masthead{#} masthead--hybrid#}">
        <div class="container px-4 px-lg-5 d-flex h-100 align-items-center justify-content-center">
            <div class="d-flex justify-content-center">
                <div class="text-center">
                    <h1 class="mx-auto my-0 text-uppercase">{{ 'hello.hero.title'|trans|raw }}</h1>
                    <h2 class="text-white-50 mx-auto mt-3 mb-4 no_link">{{ 'hello.hero.description'|trans|raw }}</h2>
                    <a class="btn btn-primary" href="#about">{{ 'hello.hero.cta'|trans }}</a>
                </div>
            </div>
        </div>
    </header>

    <section class="section about-section" id="about">
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8 text-center">
                    <h2 class="text-white mb-4">{{ 'hello.about.title'|trans }}</h2>
                </div>
            </div>
            <div class="row align-items-start gx-lg-5 gy-4 mb-4">
                <div class="col-lg-5 text-center text-lg-start">
                    <figure class="hello-about-banner mb-0">
                        <img src="{{ asset('/hello/mathieu-ledru.jpg') }}" alt="{{ hello.profile.name }}" class="img-fluid rounded-3 shadow" width="480" height="640" loading="lazy">
                    </figure>
                </div>
                <div class="col-lg-7">
                    <p class="text-white-50 lead hello-about-lead">{{ 'hello.about.lead'|trans }}</p>
                    {% if hello.profile.hero_links is not empty %}
                    <p class="text-white-50 show_links hello-about-links-list mb-4">
                        {% for link in hello.profile.hero_links %}
                            <a href="{{ link.url }}" rel="noreferrer" target="_blank">{{ link.label }}</a>{% if not loop.last %} · {% endif %}
                        {% endfor %}
                    </p>
                    {% endif %}
                    <div class="text-white-50 show_links hello-about-body">
                        <p>{{ 'hello.about.text'|trans|raw|nl2br }}</p>
                    </div>
                </div>
            </div>
            <div class="row justify-content-center g-4 mt-2">
                <div class="col-6 col-xs-4 col-xl-2">
                    <div class="d-grid gap-2 h-100">
                        <a href="#contact" class="btn btn-lg btn-primary">
                            <i class="fa fa-paper-plane"></i>
                            {{ 'hello.about.cta_contact'|trans }}
                        </a>
                    </div>
                </div>
                <div class="col-6 col-xs-4 col-xl-2">
                    <div class="d-grid gap-2 h-100">
                        <a href="{{ asset('/hello/mathieu-ledru.pdf') }}" class="btn btn-lg btn-secondary">
                            <i class="fa fa-file-alt"></i>
                            {{ 'hello.about.cta_cv'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section about-section hello-work-section" id="work">
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8 text-center">
                    <h2 class="text-white mb-4">{{ 'hello.section.work'|trans }}</h2>
                </div>
            </div>
            {% for job in hello.work %}
            <div class="row hello-work-item">
                <div class="col-12 col-lg-8 offset-lg-2 ml-auto text-white-50">
                    <h3 class="text-white h4 mb-2">{{ job.company }}</h3>
                    <p class="mb-1 text-white-50">{{ job.role }}</p>
                    <p class="hello-work-period">{{ job.period }}</p>
                    <p>{{ job.description }}</p>
                    {% if job.highlights is not empty %}
                    <ul class="hello-work-highlights">
                        {% for line in job.highlights %}
                        <li>{{ line }}</li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    {% if hello.skills is not empty %}
    <section class="section blog-area" id="skills">
        <div class="container">
            <div class="row p-5 gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8">
                    <h2 class="text-white mb-4 text-center">{{ 'hello.section.skills'|trans }}</h2>
                </div>
            </div>
            <ul class="hello-skills-compact">
                {% for skill in hello.skills %}
                <li>{{ skill.name }} · {{ skill.category }}</li>
                {% endfor %}
            </ul>
        </div>
    </section>
    {% endif %}

    <section class="section hello-showreel-section" id="showreel">
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8 text-center">
                    <h2 class="text-white mb-4">{{ 'hello.section.showreel'|trans }}</h2>
                </div>
            </div>
            <div
                class="hello-showreel"
                data-showreel
                data-audio-duration="497.533979"
                data-audio-src="{{ asset('/hello/showreel-track.mp3') }}"
                data-audio-title="{{ 'hello.showreel.meta.soundtrack_title'|trans }}"
                data-audio-unavailable="{{ 'hello.showreel.meta.soundtrack_unavailable'|trans }}"
                data-audio-blocked="{{ 'hello.showreel.meta.soundtrack_blocked'|trans }}"
                data-play-label="{{ 'hello.showreel.controls.play'|trans }}"
                data-pause-label="{{ 'hello.showreel.controls.pause'|trans }}"
            >
                <div class="hello-showreel__ambient-grid" aria-hidden="true"></div>

                <header class="hello-showreel__chrome">
                    <div class="hello-showreel__brand">
                        <span class="hello-showreel__brand-name">Darkwood</span>
                        <span class="hello-showreel__brand-caption">{{ 'hello.showreel.brand.caption'|trans }}</span>
                    </div>
                    <div class="hello-showreel__meta">
                        <span data-audio-label>{{ 'hello.showreel.meta.soundtrack_title'|trans }}</span>
                        <span>{{ 'hello.showreel.meta.timeline'|trans }}</span>
                    </div>
                </header>

                <div class="hello-showreel__player">
                    <div class="hello-showreel__stage-wrap">
                        <section class="hello-showreel__stage" data-stage>
                            <div class="hello-showreel__vignette"></div>
                            <div class="hello-showreel__grid"></div>
                            <div class="hello-showreel__stage-main" data-stage-main>
                                <div class="hello-showreel__timecode">
                                    <span data-timecode>00:00.000</span>
                                    <span>{{ 'hello.showreel.meta.study'|trans }}</span>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--opening" data-scene="opening">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">01</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.opening.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content hello-showreel__scene-content--opening">
                                        <div class="hello-showreel__title-cluster">
                                            <p class="hello-showreel__eyebrow">{{ 'hello.showreel.scenes.opening.eyebrow'|trans }}</p>
                                            <h2 class="hello-showreel__hero-title">
                                                <span class="hello-showreel__hero-line">{{ 'hello.showreel.scenes.opening.title_line_1'|trans }}</span>
                                                <span class="hello-showreel__hero-line hello-showreel__hero-line--accent">{{ 'hello.showreel.scenes.opening.title_line_2'|trans }}</span>
                                                <span class="hello-showreel__hero-line">{{ 'hello.showreel.scenes.opening.title_line_3'|trans }}</span>
                                            </h2>
                                            <p class="hello-showreel__hero-statement">
                                                {{ 'hello.showreel.scenes.opening.statement'|trans }}
                                            </p>
                                        </div>

                                        <div class="hello-showreel__hero-right">
                                            <div class="hello-showreel__instrument-panel">
                                                <div class="hello-showreel__instrument-row">
                                                    <span>Calibration</span>
                                                    <span>01 / 06</span>
                                                </div>
                                                <div class="hello-showreel__meter">
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                </div>
                                                <div class="hello-showreel__instrument-row hello-showreel__instrument-row--muted">
                                                    <span>{{ 'hello.showreel.scenes.opening.integrity'|trans }}</span>
                                                    <span>{{ 'hello.showreel.scenes.opening.integrity_status'|trans }}</span>
                                                </div>
                                            </div>

                                            {#<div class="hello-showreel__media-plate hello-showreel__media-plate--portrait">
                                                <span class="hello-showreel__media-label">Replaceable opening plate</span>
                                                <p>Portrait, title still, or short opening clip.</p>
                                            </div>#}
                                        </div>
                                    </div>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--statement" data-scene="statement">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">02</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.statement.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content">
                                        <div class="hello-showreel__statement-panel">
                                            <p class="hello-showreel__statement-kicker">{{ 'hello.showreel.scenes.statement.kicker'|trans }}</p>
                                            <p class="hello-showreel__statement-body">
                                                {{ 'hello.showreel.scenes.statement.body'|trans }}
                                            </p>
                                        </div>
                                        <div class="hello-showreel__marker-row">
                                            <article class="hello-showreel__marker-card">
                                                <span>{{ 'hello.showreel.scenes.statement.card_1_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.statement.card_1_body'|trans }}</p>
                                            </article>
                                            <article class="hello-showreel__marker-card">
                                                <span>{{ 'hello.showreel.scenes.statement.card_2_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.statement.card_2_body'|trans }}</p>
                                            </article>
                                            <article class="hello-showreel__marker-card">
                                                <span>{{ 'hello.showreel.scenes.statement.card_3_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.statement.card_3_body'|trans }}</p>
                                            </article>
                                        </div>
                                    </div>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--calibration" data-scene="calibration">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">03</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.calibration.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content hello-showreel__scene-content--split">
                                        <div class="hello-showreel__calibration-copy">
                                            <p class="hello-showreel__eyebrow">{{ 'hello.showreel.scenes.calibration.eyebrow'|trans }}</p>
                                            <h2 class="hello-showreel__scene-title">
                                                <span class="hello-showreel__scene-line">{{ 'hello.showreel.scenes.calibration.title_line_1'|trans }}</span>
                                                <span class="hello-showreel__scene-line">{{ 'hello.showreel.scenes.calibration.title_line_2'|trans }}</span>
                                            </h2>
                                        </div>
                                        <div class="hello-showreel__calibration-board">
                                            <div class="hello-showreel__signal hello-showreel__signal--wide"></div>
                                            <div class="hello-showreel__signal hello-showreel__signal--mid"></div>
                                            <div class="hello-showreel__signal hello-showreel__signal--narrow"></div>
                                            <div class="hello-showreel__board-readout">
                                                <span>{{ 'hello.showreel.scenes.calibration.readout_1_label'|trans }}</span>
                                                <strong>00.3 ms</strong>
                                            </div>
                                            <div class="hello-showreel__board-readout">
                                                <span>{{ 'hello.showreel.scenes.calibration.readout_2_label'|trans }}</span>
                                                <strong>{{ 'hello.showreel.scenes.calibration.readout_2_value'|trans }}</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--assembly" data-scene="assembly">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">04</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.assembly.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content">
                                        <div class="hello-showreel__assembly-stage">
                                            <div class="hello-showreel__assembly-grid"></div>
                                            <article class="hello-showreel__assembly-module hello-showreel__assembly-module--a">
                                                <span class="hello-showreel__assembly-index">A1</span>
                                                <h3>{{ 'hello.showreel.scenes.assembly.module_a_title'|trans }}</h3>
                                                <p>{{ 'hello.showreel.scenes.assembly.module_a_body'|trans }}</p>
                                            </article>
                                            <article class="hello-showreel__assembly-module hello-showreel__assembly-module--b">
                                                <span class="hello-showreel__assembly-index">B2</span>
                                                <h3>{{ 'hello.showreel.scenes.assembly.module_b_title'|trans }}</h3>
                                                <p>{{ 'hello.showreel.scenes.assembly.module_b_body'|trans }}</p>
                                            </article>
                                            <article class="hello-showreel__assembly-module hello-showreel__assembly-module--c">
                                                <span class="hello-showreel__assembly-index">C3</span>
                                                <h3>{{ 'hello.showreel.scenes.assembly.module_c_title'|trans }}</h3>
                                                <p>{{ 'hello.showreel.scenes.assembly.module_c_body'|trans }}</p>
                                            </article>
                                            {#<article class="hello-showreel__assembly-module hello-showreel__assembly-module--d hello-showreel__media-plate">
                                                <span class="hello-showreel__assembly-index">D4</span>
                                                <h3>Replaceable visual plate</h3>
                                                <p>UI captures, project stills, client marks, or footage.</p>
                                            </article>#}
                                        </div>
                                    </div>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--continuity" data-scene="continuity">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">05</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.continuity.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content hello-showreel__scene-content--continuity">
                                        <div class="hello-showreel__continuity-copy">
                                            <p class="hello-showreel__eyebrow">{{ 'hello.showreel.scenes.continuity.eyebrow'|trans }}</p>
                                            <h2 class="hello-showreel__scene-title">
                                                <span class="hello-showreel__scene-line">{{ 'hello.showreel.scenes.continuity.title_line_1'|trans }}</span>
                                                <span class="hello-showreel__scene-line">{{ 'hello.showreel.scenes.continuity.title_line_2'|trans }}</span>
                                            </h2>
                                        </div>
                                        <div class="hello-showreel__chain-track">
                                            <div class="hello-showreel__chain-node">
                                                <span>{{ 'hello.showreel.scenes.continuity.node_1_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.continuity.node_1_body'|trans }}</p>
                                            </div>
                                            <div class="hello-showreel__chain-link"></div>
                                            <div class="hello-showreel__chain-node">
                                                <span>{{ 'hello.showreel.scenes.continuity.node_2_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.continuity.node_2_body'|trans }}</p>
                                            </div>
                                            <div class="hello-showreel__chain-link"></div>
                                            <div class="hello-showreel__chain-node">
                                                <span>{{ 'hello.showreel.scenes.continuity.node_3_title'|trans }}</span>
                                                <p>{{ 'hello.showreel.scenes.continuity.node_3_body'|trans }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="hello-showreel__scene hello-showreel__scene--closing" data-scene="closing">
                                    <div class="hello-showreel__scene-header">
                                        <span class="hello-showreel__scene-index">06</span>
                                        <span class="hello-showreel__scene-label">{{ 'hello.showreel.scenes.closing.label'|trans }}</span>
                                    </div>
                                    <div class="hello-showreel__scene-content hello-showreel__scene-content--closing">
                                        <div class="hello-showreel__closing-panel">
                                            <p class="hello-showreel__eyebrow">{{ 'hello.showreel.scenes.closing.eyebrow'|trans }}</p>
                                            <h2 class="hello-showreel__closing-title">
                                                <span>Artisanat logiciel.</span>
                                                <span>{{ 'hello.showreel.scenes.closing.title_line_2'|trans }}</span>
                                            </h2>
                                            <p class="hello-showreel__closing-body">
                                                {{ 'hello.showreel.scenes.closing.body'|trans }}
                                            </p>
                                        </div>
                                        <div class="hello-showreel__closing-caption">
                                            <span>{{ 'hello.showreel.scenes.closing.caption_1'|trans }}</span>
                                            <span>HTML / CSS / JavaScript / GSAP</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="hello-showreel__visualizer">
                                <canvas class="hello-showreel__visualizer-canvas" data-audio-visualizer aria-hidden="true"></canvas>
                            </div>
                        </section>

                        <div class="hello-showreel__start-overlay" data-start-overlay>
                            <div class="hello-showreel__start-panel">
                                <p class="hello-showreel__start-eyebrow">{{ 'hello.showreel.start.eyebrow'|trans }}</p>
                                <h2>{{ 'hello.showreel.start.title'|trans }}</h2>
                                <p>{{ 'hello.showreel.start.body'|trans }}</p>
                                <button class="hello-showreel__start-button" type="button" data-start-button>{{ 'hello.showreel.start.button'|trans }}</button>
                            </div>
                        </div>
                    </div>

                    <footer class="hello-showreel__controls">
                        <div class="hello-showreel__controls-left">
                            <button type="button" data-play-toggle>{{ 'hello.showreel.controls.pause'|trans }}</button>
                            <button type="button" data-restart>{{ 'hello.showreel.controls.restart'|trans }}</button>
                        </div>
                        <div class="hello-showreel__controls-right">
                            <div class="hello-showreel__progress-rail">
                                <span class="hello-showreel__progress-fill" data-progress-fill></span>
                            </div>
                            <span data-scene-label>{{ 'hello.showreel.scenes.opening.label'|trans }}</span>
                        </div>
                    </footer>
                </div>

                <audio data-soundtrack preload="auto"></audio>
            </div>
        </div>
    </section>

    <section class="section projects-section" id="projects">
        <div class="container">
            <div class="row p-5 gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8">
                    <h2 class="text-white mb-4 text-center">{{ 'hello.projects.title'|trans }}</h2>
                    <p class="text-white-50 text-center">{{ 'hello.projects.description'|trans }}</p>
                </div>
            </div>
            <div class="row justify-content-center g-4">
                {% for project in hello.projects %}
                <div class="col-lg-4 col-md-8 col-sm-9">
                    {% if project.primary_url %}
                    <a href="{{ project.primary_url }}" target="_blank" rel="noreferrer" class="single-block">
                        <div class="mt-30">
                            <div class="block-image">
                                {% if project.image_asset %}
                                <img src="{{ asset(project.image_asset)|imagine_filter('hello_blog') }}" alt="{{ project.name }}">
                                {% else %}
                                <div class="hello-api-placeholder" role="presentation" aria-hidden="true"></div>
                                {% endif %}
                            </div>
                            <div class="block-content">
                                <h4 class="block-title">{{ ('hello.projects.items.' ~ project.id ~ '.title')|trans }}</h4>
                                <span>{{ ('hello.projects.items.' ~ project.id ~ '.description')|trans }}</span>
                            </div>
                        </div>
                    </a>
                    {% else %}
                    <div class="single-block">
                        <div class="mt-30">
                            <div class="block-image">
                                {% if project.image_asset %}
                                <img src="{{ asset(project.image_asset)|imagine_filter('hello_blog') }}" alt="{{ project.name }}">
                                {% else %}
                                <div class="hello-api-placeholder" role="presentation" aria-hidden="true"></div>
                                {% endif %}
                            </div>
                            <div class="block-content">
                                <h4 class="block-title">{{ ('hello.projects.items.' ~ project.id ~ '.title')|trans }}</h4>
                                <span>{{ ('hello.projects.items.' ~ project.id ~ '.description')|trans }}</span>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="section blog-area" id="blog">
        <div class="container">
            <div class="row p-5 gx-4 gx-lg-5 justify-content-center">
                <div class="col-lg-8">
                    <h2 class="text-white mb-4 text-center">{{ 'hello.blog.title'|trans }}</h2>
                    <p class="text-white-50 text-center">{{ 'hello.blog.description'|trans }}</p>
                </div>
            </div>
            <div class="row justify-content-center g-4">
                {% for article in articles %}
                {% set articleTranslation = article.getOneTranslation(app.request.locale) %}
                <div class="col-lg-4 col-md-8 col-sm-9">
                    <a href="{{ path('blog_article', {'slug': articleTranslation.slug}) }}" target="_blank" rel="noreferrer" class="single-block">
                        <div class="mt-30">
                            <div class="block-image">
                                <img src="{{ asset(vich_uploader_asset(articleTranslation, 'image')|default('/common/images/site/cover.png'))|imagine_filter('hello_blog') }}" alt="">
                            </div>
                            <div class="block-content">
                                <h4 class="block-title">{{ articleTranslation.title }}</h4>
                                <span>{{ articleTranslation.created|format_date('long') }}</span>
                            </div>
                        </div>
                    </a>
                </div>
                {% endfor %}
            </div>
            <div class="row pt-5">
                <div class="col-lg-12">
                    <div class="blog-more text-center mt-50">
                        <a class="btn btn-primary" href="{{ path('blog_home') }}">{{ 'hello.blog.cta_more'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section contact-section" id="contact">
        <div class="container px-4 px-lg-5">
            <div class="row gx-4 gx-lg-5">
                <div class="col-md-10 col-lg-8 mx-auto text-center">
                    <i class="far fa-paper-plane fa-2x mb-2 text-white"></i>
                    <h2 class="text-white mb-5">{{ 'hello.contact.title'|trans }}</h2>
                    <p class="text-white-50 mb-4 small">{{ 'hello.contact.lede'|trans }}</p>
                    <form id="contact_form" action="{{ path('hello_home') }}#contact_form" method="post" novalidate="novalidate">
                        {{ form_errors(form._token) }}
                        {{ form_widget(form._token) }}
                        {% for flashMessage in app.session.flashbag.get('success') %}<div class="alert_success">{{ flashMessage }}</div>{% endfor %}
                        {% for flashMessage in app.session.flashbag.get('error') %}<div class="alert_error">{{ flashMessage }}</div>{% endfor %}
                        {% if form.vars['errors'] |length > 0 %}<div class="alert_error">{{ form_errors(form) }}</div>{% endif %}
                        <div class="row">
                            {% if form.email.vars['errors'] |length > 0 %}<div class="col-12"><div class="mb-3"><div class="alert_error">{{ form_errors(form.email) }}</div></div></div>{% endif %}
                            <div class="col-12">
                                <div class="mb-3">
                                    {{ form_label(form.email, 'common.contact.email', {'label_attr':{'class': 'form-label text-white'}}) }}
                                    {{ form_widget(form.email, {'attr':{'class': 'form-control'} }) }}
                                </div>
                            </div>
                            {% if form.website.vars['errors'] |length > 0 %}<div class="col-12"><div class="mb-3"><div class="alert_error">{{ form_errors(form.website) }}</div></div></div>{% endif %}
                            <div class="col-12">
                                <div class="mb-3">
                                    {{ form_label(form.website, 'common.contact.website', {'label_attr':{'class': 'form-label text-white'}}) }}
                                    {{ form_widget(form.website, {'attr':{'class': 'form-control'} }) }}
                                </div>
                            </div>
                            {% if form.content.vars['errors'] |length > 0 %}<div class="col-12"><div class="mb-3"><div class="alert_error">{{ form_errors(form.content) }}</div></div></div>{% endif %}
                            <div class="col-12">
                                <div class="mb-3">
                                    {{ form_label(form.content, 'common.contact.message', {'label_attr':{'class': 'form-label text-white'}}) }}
                                    {{ form_widget(form.content, {'attr':{'class': 'form-control', 'rows': '5', 'cols': '35'} }) }}
                                </div>
                            </div>
                            {% if form.recaptcha.vars.recaptcha_enabled %}
                            {% if form.recaptcha.vars['errors'] |length > 0 %}<div class="col-12"><div class="mb-3"><div class="alert_error">{{ form_errors(form.recaptcha) }}</div></div></div>{% endif %}
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="required text-white">{{ 'common.contact.recaptcha'|trans }}</label>
                                    <div class="d-flex justify-content-center">
                                        <div class="g-recaptcha" data-sitekey="{{ form.recaptcha.vars.public_key }}"></div>
                                    </div>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <div class="text-center">
                                    <button type="submit" id="submit" name="contact_contact" class="btn btn-primary">{{ 'hello.contact.btn_send'|trans }}</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
    <div class="row theme-footer no_link">
        <div class="col-md-12">
            {%- include "hello/partials/footer.html.twig" -%}
        </div>
    </div>
    <div class="row theme-info no_link p-2">
        <div class="col-12 text-center">
            {{ 'hello.footer.credit'|trans|raw }}
        </div>
    </div>
</div>

{% endblock %}
