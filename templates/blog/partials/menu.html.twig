{% set currentRoute = app.request.attributes.get('_route') %}

<nav class="darkwood-topnav" aria-label="Blog navigation">
    <div class="darkwood-topnav__primary">
        <a class="darkwood-topnav__brand" href="{{ path('blog_home') }}">
            <img src="{{ asset('logo.svg') }}" alt="Darkwood Blog" class="darkwood-topnav__brand-mark">
            <span class="darkwood-topnav__brand-text">Blog</span>
        </a>

        <ul class="darkwood-topnav__links">
            <li>
                <a href="{{ path('blog_home') }}" class="{% if currentRoute == 'blog_home' or currentRoute == 'blog_article' %}is-active{% endif %}">
                    {{ 'blog.menu.articles'|trans }}
                </a>
            </li>
        </ul>
    </div>

    <div class="darkwood-topnav__actions">
        <div class="darkwood-topnav__locales dropdown" aria-label="Locales">
            <a href="#" class="dropdown-toggle darkwood-topnav__locale-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="{{ asset('/common/images/site/flags/' ~ app.request.locale ~ '.png') }}" alt="{{ app.request.locale }}" class="darkwood-topnav__flag">
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                {% for locale, pageLink in pageLinks %}
                    <li>
                        <a href="{{ pageLink }}" class="dropdown-item{% if app.request.locale == locale %} active{% endif %}">
                            <img src="{{ asset('/common/images/site/flags/' ~ locale ~ '.png') }}" alt="{{ locale }}" class="darkwood-topnav__flag">
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>

        {% if app.user %}
            <a class="darkwood-topnav__profile" href="{{ path('common_profile') }}">
                <img src="{{ asset(vich_uploader_asset(app.user, 'image')|default('/common/images/profile/default.jpg'))|imagine_filter('user') }}" alt="{{ app.user.username }}">
                <span>{{ app.user.username }}</span>
            </a>
            <form action="{{ path('security_logout') }}" method="get">
                <button type="submit" class="darkwood-topnav__button darkwood-topnav__button--logout">
                    {{ 'common.menu.logout_btn'|trans }}
                </button>
            </form>
        {% else %}
            <a class="darkwood-topnav__button darkwood-topnav__button--login" href="{{ path('security_login') }}">
                {{ 'common.menu.login_btn'|trans }}
            </a>
        {% endif %}
    </div>
</nav>

<ul class="darkwood-mobile-nav">
    <li class="darkwood-mobile-nav__home">
        <a href="{{ path('blog_home') }}" class="{% if currentRoute == 'blog_home' %}is-active{% endif %}">
            Blog
        </a>
    </li>
    <li>
        <a href="{{ path('blog_home') }}" class="{% if currentRoute == 'blog_home' or currentRoute == 'blog_article' %}is-active{% endif %}">
            {{ 'blog.menu.articles'|trans }}
        </a>
    </li>
</ul>
