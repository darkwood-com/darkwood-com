{% extends "blog/base.html.twig" %}

{% block content %}

<h1>{{ page.title }}</h1>
{# page.content|markdown_to_html #}

{% if lastAutoArticle %}
<h2>{{ 'blog.home.automation_heading'|trans }}</h2>
<ul class="itemlist">
    {% set autoTranslation = lastAutoArticle.getOneTranslation(app.request.locale) %}
    <li>
        <h3>{{ autoTranslation.title }} <em>{{ 'blog.home.article_on'|trans }} {{ autoTranslation.created|format_date('long') }}</em></h3>
        <p>{{ autoTranslation.content|markdown_to_html|striptags|u.truncate(260, '...') }}</p>
        <p>
            {#<a href="{{ path('blog_article', {'slug': autoTranslation.slug}) }}">{{ 'blog.home.automation_read'|trans }}</a>
            ·
            <a href="{{ path('blog_auto') }}">{{ 'blog.home.show_more'|trans }}</a>#}
            <a href="{{ path('blog_article', {'slug': autoTranslation.slug}) }}">{{ 'blog.home.show_more'|trans }}</a>
        </p>
    </li>
</ul>
{% endif %}

<h2>{{ 'blog.home.news_heading'|trans }}</h2>

<ul class="itemlist">
    {% for article in articles %}
        {% set articleTranslation = article.getOneTranslation(app.request.locale) %}
        <li>
            <h3>{{ articleTranslation.title }} <em>{{ 'blog.home.article_on'|trans }} {{ articleTranslation.created|format_date('long') }}</em></h3>
            <p>{{ articleTranslation.content|markdown_to_html|striptags|u.truncate(260, '...') }}</p>
            <p><a href="{{ path('blog_article', {'slug': articleTranslation.slug}) }}">{{ 'blog.home.show_more'|trans }}</a></p>
        </li>
    {% endfor %}
</ul>

{{ knp_pagination_render(articles, 'common/partials/sliding.html.twig') }}

{% endblock %}
