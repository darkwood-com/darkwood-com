{% set currentRoute = app.request.attributes.get('_route') %}
{% set communityRoutes = ['darkwood_chat', 'darkwood_users', 'darkwood_guestbook'] %}
{% set rankMode = app.request.get('mode') %}
{% set communityActive = currentRoute in communityRoutes %}
{% set rankActive = currentRoute == 'darkwood_rank' %}

<nav class="darkwood-topnav" aria-label="Darkwood navigation">
    <div class="darkwood-topnav__primary">
        <a class="darkwood-topnav__brand" href="{{ path('darkwood_home') }}">
            <span class="darkwood-topnav__brand-mark" aria-hidden="true"></span>
            <span class="darkwood-topnav__brand-text">Darkwood</span>
        </a>

        <ul class="darkwood-topnav__links">
            <li>
                <a href="{{ path('darkwood_play') }}" class="{% if currentRoute == 'darkwood_play' %}is-active{% endif %}">
                    {{ 'darkwood.menu.play'|trans }}
                </a>
            </li>
            <li class="dropdown">
                <a href="#" class="dropdown-toggle{% if communityActive %} is-active{% endif %}" data-bs-toggle="dropdown" aria-expanded="false">
                    Communauté
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item{% if currentRoute == 'darkwood_chat' %} active{% endif %}" href="{{ path('darkwood_chat') }}">
                            {{ 'darkwood.menu.chat'|trans }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item{% if currentRoute == 'darkwood_users' %} active{% endif %}" href="{{ path('darkwood_users') }}">
                            {{ 'darkwood.menu.users'|trans }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item{% if currentRoute == 'darkwood_guestbook' %} active{% endif %}" href="{{ path('darkwood_guestbook') }}">
                            {{ 'darkwood.menu.guestbook'|trans }}
                        </a>
                    </li>
                </ul>
            </li>
            <li class="dropdown">
                <a href="#" class="dropdown-toggle{% if rankActive %} is-active{% endif %}" data-bs-toggle="dropdown" aria-expanded="false">
                    Classement
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item{% if rankActive and not rankMode %} active{% endif %}" href="{{ path('darkwood_rank') }}">
                            {{ 'darkwood.menu.rank_general'|trans }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item{% if rankMode == 'by_class_human' %} active{% endif %}" href="{{ path('darkwood_rank', {'mode': 'by_class_human'}) }}">
                            {{ 'darkwood.menu.rank_by_class'|trans }}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item{% if rankMode == 'daily_fight_by_defeats' %} active{% endif %}" href="{{ path('darkwood_rank', {'mode': 'daily_fight_by_defeats'}) }}">
                            {{ 'darkwood.menu.rank_daily_fight'|trans }}
                        </a>
                    </li>
                </ul>
            </li>
            <li>
                <a href="{{ path('darkwood_rules') }}" class="{% if currentRoute == 'darkwood_rules' %}is-active{% endif %}">
                    {{ 'darkwood.menu.rules'|trans }}
                </a>
            </li>
        </ul>
    </div>

    <div class="darkwood-topnav__actions">
        <div class="darkwood-topnav__locales" aria-label="Locales">
            {% for locale, pageLink in pageLinks %}
                <a href="{{ pageLink }}" class="{% if app.request.locale == locale %}is-active{% endif %}">
                    {{ locale|upper }}
                </a>
            {% endfor %}
        </div>

        {% if app.user %}
            <a class="darkwood-topnav__profile" href="{{ path('common_profile') }}">
                <img src="{{ asset(vich_uploader_asset(app.user, 'image')|default('/common/images/profile/default.jpg'))|imagine_filter('user') }}" alt="{{ app.user.username }}">
                <span>{{ app.user.username }}</span>
            </a>
            <form action="{{ path('security_logout') }}" method="get">
                <button type="submit" class="darkwood-topnav__button darkwood-topnav__button--ghost">
                    {{ 'common.menu.logout_btn'|trans }}
                </button>
            </form>
        {% else %}
            <a class="darkwood-topnav__button darkwood-topnav__button--ghost" href="{{ path('common_register') }}">
                {{ 'common.menu.register'|trans }}
            </a>
            <a class="darkwood-topnav__button" href="{{ path('security_login') }}">
                {{ 'common.menu.login_btn'|trans }}
            </a>
        {% endif %}
    </div>
</nav>
