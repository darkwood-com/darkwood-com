<div id="footer-top" class="col-md-12">
    <div class="darkwood-footer">
        <div class="darkwood-footer__columns">
            <section class="darkwood-footer__column">
                <h4 class="darkwood-footer__title">Site</h4>
                <ul class="darkwood-footer__links">
                    <li><a href="{{ path('darkwood_sitemap') }}">{{ 'common.footer.sitemap'|trans }}</a></li>
                    <li><a href="{{ path('darkwood_contact') }}">{{ 'common.footer.contact'|trans }}</a></li>
                    <li><a href="{{ path('darkwood_legal_mention') }}">{{ 'common.footer.legal_mention'|trans }}</a></li>
                </ul>
            </section>

            <section class="darkwood-footer__column">
                <h4 class="darkwood-footer__title">Network</h4>
                <ul class="darkwood-footer__links">
                    <li><a href="{{ path('hello_home') }}">{{ 'common.footer.hello'|trans }}</a></li>
                    <li><a href="{{ path('blog_home') }}">{{ 'common.footer.blog'|trans }}</a></li>
                    <li><a href="{{ path('apps_home') }}">{{ 'common.footer.apps'|trans }}</a></li>
                    <li><a href="{{ path('photos_home') }}">{{ 'common.footer.photos'|trans }}</a></li>
                </ul>
            </section>

            <section class="darkwood-footer__column darkwood-footer__column--social">
                <h4 class="darkwood-footer__title">Social</h4>
                <div class="darkwood-footer__socials">
                    <a class="darkwood-footer__social btn btn-social-icon btn-github" aria-label="Visit our GitHub" href="https://github.com/darkwood-com" target="_blank" rel="noreferrer"><span class="fab fa-github"></span></a>
                    <a class="darkwood-footer__social btn btn-social-icon btn-github" aria-label="Follow us on Twitter" href="https://twitter.com/darkwood_com" target="_blank" rel="noreferrer"><span class="fab fa-twitter"></span></a>
                    <a class="darkwood-footer__social btn btn-social-icon btn-linkedin" aria-label="Connect with us on LinkedIn" href="https://www.linkedin.com/company/darkwood-com" target="_blank" rel="noreferrer"><span class="fab fa-linkedin"></span></a>
                    <a class="darkwood-footer__social btn btn-social-icon btn-discord" aria-label="Join our Discord" href="https://discord.gg/TDkvp3nn3j" target="_blank" rel="noreferrer"><span class="fab fa-discord"></span></a>
                </div>
            </section>
        </div>

        <div class="darkwood-footer__bottom">
            <p class="darkwood-footer__copyright">{{ 'common.footer.copyright'|trans({'%year%': 'now'|date('Y')}) }}</p>
        </div>
    </div>
