{% extends "darkwood/base.html.twig" %}

{% block content %}
<h1>{{ page.title }}</h1>

<a href="{{ path('hello_home') }}" class="hello">
<ul class="itemlist">
    <li>
        <h2>{{ 'darkwood.home.hello_title'|trans }}</h2>
        <p>{{ 'darkwood.home.hello_content'|trans|raw }}</p>
    </li>
</ul>
</a>

{% if lastAutoArticle %}
<h2>{{ 'blog.home.automation_heading'|trans }}</h2>
<ul class="itemlist">
    {% set autoTranslation = lastAutoArticle.getOneTranslation(app.request.locale) %}
    <li>
        <h3>{{ autoTranslation.title }} <em>{{ 'blog.home.article_on'|trans }} {{ autoTranslation.created|format_date('long') }}</em></h3>
        <p>{{ autoTranslation.content|markdown_to_html|striptags|u.truncate(260, '...') }}</p>
        <p>
            <a href="{{ path('blog_article', {'slug': autoTranslation.slug}) }}">{{ 'darkwood.home.show_more'|trans }}</a>{#<a href="{{ path('blog_auto') }}">{{ 'blog.home.automation_all'|trans }}</a>#}
        </p>
        {{ include('blog/partials/article-reactions.html.twig', {
            article: lastAutoArticle,
            slug: autoTranslation.slug,
            summary: reactionSummaries[lastAutoArticle.id]|default({counts: {}, userReactions: []}),
            reactionEmojis: reactionEmojis,
            compact: true,
        }) }}
    </li>
</ul>
{% endif %}

{% if lastReleaseArticle %}
<h2>{{ 'blog.home.release_heading'|trans }}</h2>
<ul class="itemlist">
    {% set releaseTranslation = lastReleaseArticle.getOneTranslation(app.request.locale) %}
    <li>
        <h3>{{ releaseTranslation.title }} <em>{{ 'blog.home.article_on'|trans }} {{ releaseTranslation.created|format_date('long') }}</em></h3>
        <p>{{ releaseTranslation.content|markdown_to_html|striptags|u.truncate(260, '...') }}</p>
        <p>
            <a href="{{ path('blog_article', {'slug': releaseTranslation.slug}) }}">{{ 'darkwood.home.show_more'|trans }}</a>
        </p>
        {{ include('blog/partials/article-reactions.html.twig', {
            article: lastReleaseArticle,
            slug: releaseTranslation.slug,
            summary: reactionSummaries[lastReleaseArticle.id]|default({counts: {}, userReactions: []}),
            reactionEmojis: reactionEmojis,
            compact: true,
        }) }}
    </li>
</ul>
{% endif %}

<h2>{{ 'darkwood.home.news'|trans }}</h2>
<ul class="itemlist">
    {% for article in news %}
    {% set articleTranslation = article.getOneTranslation(app.request.locale) %}
    <li>
        <h3>{{ articleTranslation.title }} <em>{{ 'darkwood.home.news_on'|trans }} {{ articleTranslation.created|format_date('long') }}</em></h3>
        <p>{{ articleTranslation.content|markdown_to_html|striptags|u.truncate(260, '...') }}</p>
        <p><a href="{{ path('blog_article', {'slug': articleTranslation.slug}) }}">{{ 'darkwood.home.show_more'|trans }}</a></p>
        {{ include('blog/partials/article-reactions.html.twig', {
            article: article,
            slug: articleTranslation.slug,
            summary: reactionSummaries[article.id]|default({counts: {}, userReactions: []}),
            reactionEmojis: reactionEmojis,
            compact: true,
        }) }}
    </li>
    {% endfor %}
</ul>
{% endblock %}
